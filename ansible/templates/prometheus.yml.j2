global:
  scrape_interval: 15s
  evaluation_interval: 15s

  external_labels:
    monitor: 'ubuntu-monitor'

scrape_configs:

  - job_name: "prometheus"
    static_configs:
      - targets: ["localhost:9090"]

  - job_name: "backend_fast_app"
    metrics_path: /metrics
    static_configs:
      - targets:
{% for host in groups['backend'] %}
          - "{{ hostvars[host].private_ip }}:8000"
{% endfor %}

  - job_name: "node_exporter"
    static_configs:
      - targets:
          - "localhost:9100"
{% for host in groups['frontend'] %}
          - "{{ hostvars[host].private_ip }}:9100"
{% endfor %}
{% for host in groups['backend'] %}
          - "{{ hostvars[host].private_ip }}:9100"
{% endfor %}